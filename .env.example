# Copy to .env (gitignored) and fill in. Load with:  set -a; source .env; set +a

ANTHROPIC_API_KEY=sk-ant-your-key-here

# Salesforce — OAuth 2.0 Client Credentials Flow (server-to-server).
# In the Connected App: enable "Client Credentials Flow" + set a Run-As user.
# No username/password/security-token — the legacy password flow is disabled
# in Summer '23+ orgs.
SF_CONSUMER_KEY=your-connected-app-consumer-key
SF_CONSUMER_SECRET=your-connected-app-consumer-secret
# My Domain URL from the Setup address bar, e.g.
# https://orgfarm-xxxx-dev-ed.develop.my.salesforce.com
SF_INSTANCE_URL=https://your-mydomain.my.salesforce.com
